VERSION 5.7 ;
  NOWIREEXTENSIONATPIN ON ;
  DIVIDERCHAR "/" ;
  BUSBITCHARS "[]" ;
MACRO TOP
  CLASS BLOCK ;
  FOREIGN TOP ;
  ORIGIN 1.035 1.180 ;
  SIZE 1.685 BY 2.060 ;
  PIN VPWR
    ANTENNADIFFAREA 0.100500 ;
    PORT
      LAYER Metal1 ;
        RECT -0.995 0.295 -0.300 0.550 ;
        RECT -0.995 0.290 -0.695 0.295 ;
        RECT -0.460 0.290 -0.300 0.295 ;
    END
  END VPWR
  PIN VGND
    ANTENNADIFFAREA 0.100500 ;
    PORT
      LAYER Metal1 ;
        RECT -1.035 -1.030 -0.300 -0.750 ;
    END
  END VGND
  PIN ethernet_dn
    ANTENNADIFFAREA 0.201000 ;
    PORT
      LAYER Metal1 ;
        RECT 0.110 -1.030 0.270 0.550 ;
    END
  END ethernet_dn
  PIN data_in
    ANTENNAGATEAREA 0.039000 ;
    PORT
      LAYER GatPoly ;
        RECT -0.160 0.495 -0.030 0.675 ;
        RECT -0.160 -0.825 -0.030 0.345 ;
        RECT -0.160 -1.155 -0.030 -0.975 ;
    END
  END data_in
END TOP
END LIBRARY

